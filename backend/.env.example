# PostgreSQL connection string (Railway/Render/Supabase all provide one)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Secret used to sign JWTs — use a long random string in production
JWT_SECRET="change-this-to-a-long-random-string"

# Comma-separated list of allowed frontend origins (your deployed frontend URL)
FRONTEND_URL="https://your-frontend.vercel.app"

# Port the server listens on (most hosts set this automatically)
PORT=5000

# Email (used for password reset links). Works with Gmail (App Password), Brevo, SendGrid, etc.
# via standard SMTP. If left unset, forgot-password requests are logged server-side but no
# email is actually sent — useful for local dev, but set these before going live.
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=587
EMAIL_USER="your-email@gmail.com"
EMAIL_PASS="your-16-character-app-password"
EMAIL_FROM="Elma's Fashion <your-email@gmail.com>"
