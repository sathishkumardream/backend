# PostgreSQL connection string (Railway/Render/Supabase all provide one)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Secret used to sign JWTs — use a long random string in production
JWT_SECRET="change-this-to-a-long-random-string"

# Comma-separated list of allowed frontend origins (your deployed frontend URL)
FRONTEND_URL="https://your-frontend.vercel.app"

# Port the server listens on (most hosts set this automatically)
PORT=5000

# Email (used for password reset links) via Brevo's HTTP API — not SMTP, since some
# hosts block outbound SMTP ports. If left unset, forgot-password requests are logged
# server-side but no email is actually sent — useful for local dev, but set these before going live.
# 1. Sign up free at https://www.brevo.com (300 emails/day free, no credit card)
# 2. Get an API key: https://app.brevo.com/settings/keys/api
# 3. Verify a sender email: Brevo dashboard → Senders, Domains & Dedicated IPs
BREVO_API_KEY="your-brevo-api-key"
EMAIL_FROM_NAME="Elma's Fashion"
EMAIL_FROM_ADDRESS="your-verified-sender@example.com"
